@startuml
autonumber

actor Usuario
participant "PaginaLoginAngular" as Angular
participant "ControladorAutenticacion" as Controlador
participant "ServicioAutenticacion" as Servicio
participant "RepositorioUsuarios" as RepositorioUsuarios
participant "CodificadorContrasena" as Codificador
participant "ServicioTokenJwt" as ServicioJwt
participant "RepositorioTokenActualizacion" as RepositorioToken
database "MySQL" as BD

Usuario -> Angular : correo + contrasena
Angular -> Controlador : POST /api/v1/auth/iniciar-sesion
Controlador -> Servicio : iniciarSesion(comando)

Servicio -> RepositorioUsuarios : buscarPorEmpresaYCorreo()
RepositorioUsuarios -> BD : SELECT usuario
BD --> RepositorioUsuarios : usuario
RepositorioUsuarios --> Servicio : usuario

Servicio -> Codificador : coincide(raw, hash)
Codificador --> Servicio : true

Servicio -> ServicioJwt : generarTokenAcceso(usuario, roles)
ServicioJwt --> Servicio : tokenAcceso

Servicio -> ServicioJwt : generarTokenActualizacion(usuario)
ServicioJwt --> Servicio : tokenActualizacion

Servicio -> RepositorioToken : guardar(tokenHash)
RepositorioToken -> BD : INSERT token_actualizacion

Servicio --> Controlador : TokenJwt
Controlador --> Angular : 200 OK
@enduml
