  usecase "Consultar mis citas" as U10
  usecase "Consultar agenda personal" as U11
  usecase "Confirmar cita" as U12
  usecase "Finalizar cita" as U13
  usecase "Marcar no asistio" as U14
  usecase "Registrar excepcion de agenda" as U15
  usecase "Gestionar sucursales" as U16
  usecase "Gestionar servicios" as U17
  usecase "Gestionar prestadores" as U18
  usecase "Asignar servicios a prestadores" as U19
