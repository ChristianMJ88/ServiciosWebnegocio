Staff --> U12
Staff --> U13
Staff --> U14
Staff --> U15

Admin --> U6
Admin --> U16
Admin --> U17
Admin --> U18
Admin --> U19
Admin --> U20
Admin --> U21
Admin --> U22
Admin --> U23

U6 .> U24 : <<include>>
U7 .> U25 : <<include>>
U9 .> U25 : <<include>>
U7 .> U26 : <<extend>>
U8 .> U26 : <<extend>>
U12 .> U26 : <<extend>>

